# ─────────────────────────────────────────────
#  Secure Node — Backend Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────

# Server
PORT=5000

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Hardhat / Local Blockchain ─────────────────
# URL of the local Hardhat node (keep default unless you changed it)
HARDHAT_URL=http://127.0.0.1:8545

# Private keys from `npx hardhat node` output (these are Hardhat test keys — safe for local dev only)
ADMIN1_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ADMIN2_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
AUDITOR_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# ── Wallet Access Control ──────────────────────
# Comma-separated Ethereum addresses that get the admin role on wallet login
ADMIN_WALLETS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266,0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Comma-separated Ethereum addresses that get the auditor role on wallet login
AUDITOR_WALLETS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
